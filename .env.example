# ══════════════════════════════════════════════════════════════════════════
# Next.js (Vercel) — SOLO claves públicas. Los secretos NO viven acá.
# Regla de arquitectura: todo lo que necesita un secreto (Stripe, YeSim,
# Resend) o service_role corre en Supabase Edge Functions, con los secretos
# en `supabase secrets` (la service_role key se inyecta sola en las funciones).
# ══════════════════════════════════════════════════════════════════════════

# Supabase — públicas (van al navegador; RLS protege los datos)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe — solo la publishable (el Payment Element corre en el navegador)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Anon JWT legacy (público): Bearer para que las Server Actions invoquen
# Edge Functions con verify_jwt (las claves sb_publishable_ no son JWT).
SUPABASE_FUNCTIONS_ANON_JWT=

# App
APP_URL=http://localhost:3000

# ══════════════════════════════════════════════════════════════════════════
# Supabase Edge Functions — referencia de secretos (configurar con
# `supabase secrets set` o en Dashboard > Edge Functions > Secrets;
# NUNCA en este repo ni en Vercel):
#   STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET
#   YESIM_BASE_URL, YESIM_TOKEN        (dev: mock — la API real consume saldo)
#   RESEND_API_KEY, EMAIL_FROM
# ══════════════════════════════════════════════════════════════════════════
